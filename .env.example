DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@localhost:5432/kortex_db
# Use Gemini (free tier friendly) and/or Anthropic. With LLM_PROVIDER=auto, Gemini is preferred if both are set.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite
LLM_PROVIDER=auto
DAILY_CHAT_REQUEST_LIMIT=50
DAILY_CHAT_TOKEN_LIMIT=100000
ANTHROPIC_API_KEY=your_anthropic_api_key_here
JWT_SECRET_KEY=your_super_secret_jwt_key_change_this
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
UPLOAD_DIR=./uploads
CHROMA_DIR=./chroma_db
CORS_ORIGINS=http://localhost:3000
